{
   "action": {
      "default_icon": {
         "16": "icon16.png",
         "32": "icon32.png",
         "48": "icon48.png",
         "128": "icon128.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "description": "Export your X bookmarks, with full article text, images, and engagement stats, to Markdown, PDF, JSON, CSV, or ZIP.",
   "icons": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
   },
   "manifest_version": 3,
   "name": "GIMMIE - X Bookmark Exporter",
   "permissions": [ "activeTab", "scripting", "storage" ],
   "host_permissions": [ "https://x.com/*" ],
   "version": "1.1"
}
